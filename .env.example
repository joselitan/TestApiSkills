# Flask Application Configuration
# Copy this file to .env and update with your values

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Secret key for JWT token generation and session management
# IMPORTANT: Change this in production to a strong random string
SECRET_KEY=your-secret-key-change-in-production

# Base URL for the application (used in emails and redirects)
APP_BASE_URL=http://localhost:8080

# Environment: development, staging, or production
ENVIRONMENT=development

# =============================================================================
# RATE LIMITING CONFIGURATION (NEW!)
# =============================================================================

# Default rate limit for all routes (can be overridden per endpoint)
# Format: "X per minute, Y per hour, Z per day"
RATE_LIMIT_DEFAULT=1000 per hour, 100 per minute

# Storage backend for rate limiting
# Development: memory:// (simple, but resets on restart)
# Production: redis://localhost:6379 (persistent, scalable)
RATE_LIMIT_STORAGE_URI=memory://

# For production with Redis:
# RATE_LIMIT_STORAGE_URI=redis://localhost:6379/0
# or with password:
# RATE_LIMIT_STORAGE_URI=redis://:password@localhost:6379/0

# =============================================================================
# DATABASE SETTINGS
# =============================================================================

# Database URL (SQLite by default)
# SQLite: sqlite:///data/guestbook.db
# PostgreSQL: postgresql://user:password@localhost/dbname
# MySQL: mysql://user:password@localhost/dbname
DATABASE_URL=sqlite:///data/guestbook.db

# =============================================================================
# EMAIL CONFIGURATION (Optional - for email verification and password reset)
# =============================================================================

# Email server settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# Email credentials
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Sender email address
EMAIL_FROM=noreply@example.com

# Email security
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false

# Debug mode for email (logs emails instead of sending in development)
EMAIL_DEBUG=true

# =============================================================================
# AUTHENTICATION SETTINGS
# =============================================================================

# Enable/disable self-registration
# true = users can register themselves
# false = only admin can create accounts
ENABLE_SELF_REGISTRATION=true

# Default role for new users
# Options: member, tester
DEFAULT_ROLE=member

# Allowed roles for registration
# Format: comma-separated list
ALLOWED_ROLES=member,tester

# =============================================================================
# TOKEN EXPIRATION SETTINGS
# =============================================================================

# Email verification token expiration (in hours)
VERIFICATION_TOKEN_EXPIRATION_HOURS=24

# Password reset token expiration (in hours)
PASSWORD_RESET_TOKEN_EXPIRATION_HOURS=2

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (relative to project root)
LOG_FILE=logs/app.log

# =============================================================================
# CORS SETTINGS (Optional - for frontend applications)
# =============================================================================

# Enable CORS for cross-origin requests
ENABLE_CORS=false

# Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================

# Test database URL (used during testing)
TEST_DATABASE_URL=sqlite:///data/guestbook_test.db

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================

# Number of workers for production deployment
WORKERS=4

# Request timeout (in seconds)
TIMEOUT=30

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable specific features
ENABLE_WEBHOOKS=true
ENABLE_REACTIONS=true
ENABLE_SWAGGER=true

# =============================================================================
# MONITORING & METRICS
# =============================================================================

# Enable application metrics
ENABLE_METRICS=false

# Metrics port (if enabled)
METRICS_PORT=9090

# =============================================================================
# REDIS CONFIGURATION (For production rate limiting)
# =============================================================================

# Redis host
REDIS_HOST=localhost

# Redis port
REDIS_PORT=6379

# Redis password (if required)
# REDIS_PASSWORD=your-redis-password

# Redis database number
REDIS_DB=0

# Redis connection timeout (in seconds)
REDIS_TIMEOUT=5

# =============================================================================
# NOTES
# =============================================================================

# 1. NEVER commit the actual .env file to version control
# 2. Always use strong, unique values for SECRET_KEY in production
# 3. For email functionality, use app-specific passwords (not your main password)
# 4. In production, use Redis for rate limiting instead of memory storage
# 5. Set ENVIRONMENT=production when deploying
# 6. Enable HTTPS in production and update APP_BASE_URL accordingly
# 7. Review and adjust rate limits based on your needs

# =============================================================================
# RATE LIMITING EXAMPLES
# =============================================================================

# Very strict (for high-security applications):
# RATE_LIMIT_DEFAULT=100 per hour, 10 per minute

# Moderate (default, good for most applications):
# RATE_LIMIT_DEFAULT=1000 per hour, 100 per minute

# Lenient (for internal tools or development):
# RATE_LIMIT_DEFAULT=10000 per hour, 500 per minute

# =============================================================================
# GMAIL APP PASSWORD SETUP
# =============================================================================

# To use Gmail for sending emails:
# 1. Enable 2-factor authentication on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an app password for "Mail"
# 4. Use that password as EMAIL_PASSWORD (not your regular password)

# =============================================================================
# REDIS SETUP FOR PRODUCTION
# =============================================================================

# Install Redis:
#   macOS: brew install redis
#   Ubuntu: sudo apt-get install redis-server
#   Docker: docker run -d -p 6379:6379 redis:7-alpine

# Install Python Redis client:
#   pip install redis

# Update RATE_LIMIT_STORAGE_URI:
#   RATE_LIMIT_STORAGE_URI=redis://localhost:6379/0
